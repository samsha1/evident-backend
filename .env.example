# ── Database (Docker Compose local) ──
DATABASE_URL=postgresql+asyncpg://evident:evident_password@localhost:5432/evident_db

# ── Redis (Docker Compose local) ──
REDIS_URL=redis://localhost:6379/0

# ── Auth (Google OAuth) ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
JWT_SECRET_KEY=change-this-to-a-random-secret

# ── Crawler API Keys ──
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=evident/0.1.0
YOUTUBE_API_KEY=your-youtube-api-key

# ── Sentiment ──
SENTIMENT_MODEL_NAME=cardiffnlp/twitter-roberta-base-sentiment-latest
OPENAI_API_KEY=your-openai-api-key

# ── Rate Limiting ──
DEFAULT_DAILY_LIMIT=10

# ── Server ──
APP_ENV=development
APP_DOMAIN=v0.app.agenco.io
CORS_ORIGINS=chrome-extension://*,http://localhost:3000
