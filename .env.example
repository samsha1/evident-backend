# Database configuration (Neon)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-restless-snowflake-xxx.region.aws.neon.tech/neondb?sslmode=require

# Vercel KV (Upstash Redis)
KV_URL=redis://default:pass@dominant-mule-12345.upstash.io:31234

# Search Engine (Typesense on Railway)
TYPESENSE_API_KEY=your_typesense_api_key
TYPESENSE_HOST=typesense-production-xxx.up.railway.app
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https

# Object Storage (Cloudflare R2)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=evident-raw-reviews-bronze

# Crawler API Keys
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
YOUTUBE_API_KEY=your_youtube_api_key

# Prefect Configuration (Railway / Render)
PREFECT_API_URL=https://prefect-production-xxx.up.railway.app/api
PREFECT_API_KEY=your_prefect_api_key
