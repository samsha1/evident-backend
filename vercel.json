{
  "builds": [
    {
      "src": "apps/api/src/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "apps/api/src/main.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/trigger-crawls",
      "schedule": "0 0 * * *"
    }
  ]
}
